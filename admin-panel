<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Admin Panel - Territori FUTCAT</title>

<style>

body {
  margin:0;
  background:#0a0a0a;
  color:white;
  font-family:Arial;
}

header {
  background:#111;
  padding:15px;
  text-align:center;
  font-weight:bold;
}

.container {
  max-width:800px;
  margin:auto;
  padding:20px;
}

.card {
  background:#111;
  padding:15px;
  margin-bottom:10px;
  border-radius:10px;
}

input {
  width:100%;
  padding:10px;
  margin:5px 0;
  background:#1a1a1a;
  border:1px solid #333;
  color:white;
}

button {
  width:100%;
  padding:10px;
  background:#00ff88;
  border:none;
  font-weight:bold;
  cursor:pointer;
}

</style>
</head>

<body>

<header>⚽ ADMIN PANEL - PASO 2.1</header>

<div class="container">

  <div class="card">
    <h3>➕ Nuevo Partido</h3>

    <input id="liga" placeholder="Liga">
    <input id="jornada" placeholder="Jornada">
    <input id="local" placeholder="Local">
    <input id="visitante" placeholder="Visitante">
    <input id="gl" type="number" placeholder="Goles local">
    <input id="gv" type="number" placeholder="Goles visitante">

    <button onclick="saveMatch()">Guardar partido</button>
  </div>

</div>

<script>

const API = "https://fcf-headless.onrender.com";

/* =========================
   GUARDAR PARTIDO REAL
========================= */

async function saveMatch() {

  const token = localStorage.getItem("token");

  if (!token) {
    alert("❌ No hay sesión activa");
    return;
  }

  const match = {
    liga: document.getElementById("liga").value,
    jornada: document.getElementById("jornada").value,
    local: document.getElementById("local").value,
    visitante: document.getElementById("visitante").value,
    goles_local: Number(document.getElementById("gl").value),
    goles_visitante: Number(document.getElementById("gv").value)
  };

  try {

    const res = await fetch(API + "/partido", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": token
      },
      body: JSON.stringify(match)
    });

    const data = await res.json();

    if (data.ok) {
      alert("✅ Partido guardado correctamente");

      // limpiar campos
      document.getElementById("local").value = "";
      document.getElementById("visitante").value = "";
      document.getElementById("gl").value = "";
      document.getElementById("gv").value = "";

    } else {
      alert("❌ Error al guardar partido");
    }

  } catch (err) {
    console.error(err);
    alert("❌ Error de conexión con el servidor");
  }
}

</script>

</body>
</html>
